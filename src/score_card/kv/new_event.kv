<NewEventScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(16)
        md_bg_color: self.theme_cls.bg_color

        MDLabel:
            size_hint_y: None
            height: dp(10)

        MDLabel:
            text: "New Event"
            font_style: "Headline"
            role: "large"
            halign: "center"
            size_hint_y: None
            height: dp(70)
            theme_text_color: "Primary"

        MDTextField:
            id: name_input
            hint_text: "Event name *"
            size_hint_y: None
            height: dp(48)

        MDButton:
            style: "tonal"
            size_hint_x: 1
            size_hint_y: None
            height: dp(52)
            on_release: root.show_date_picker()

            MDButtonText:
                text: "Select Date"
                theme_text_color: "Primary"
                color: 1, 1, 1, 1


        MDTextField:
            id: location_input
            hint_text: "Location"
            size_hint_y: None
            height: dp(48)

        MDTextField:
            id: notes_input
            hint_text: "Notes"
            size_hint_y: None
            height: dp(110)
            multiline: True

        MDLabel:
            text: root.status_message if hasattr(root, 'status_message') else ""
            size_hint_y: None
            height: dp(30)
            halign: "center"
            theme_text_color: "Custom"
            text_color: 0.3, 0.9, 0.3, 1

        Widget:   # Spacer
            size_hint_y: 1

        # Bottom action buttons
        MDButton:
            style: "elevated"
            size_hint_x: 1
            size_hint_y: None
            height: dp(54)
            on_release: root.save_event()

            MDButtonText:
                text: "Save Event"
                theme_text_color: "Primary"
                color: 1, 1, 1, 1


        MDButton:
            style: "outlined"
            size_hint_x: 1
            size_hint_y: None
            height: dp(54)
            on_release: root.go_back()

            MDButtonText:
                text: "Cancel"
                theme_text_color: "Primary"
                color: 1, 1, 1, 1
